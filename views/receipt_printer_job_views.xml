<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="job_view_list" model="ir.ui.view">
        <field name="name">receipt_printer.print.job.list</field>
        <field name="model">receipt_printer.print.job</field>
        <field name="arch" type="xml">
            <list>
                <field name="printer_id"/>
                <field name="state"/>
                <field name="create_date"/>
                <field name="printed_date"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <record id="job_action" model="ir.actions.act_window">
        <field name="name">Print Jobs</field>
        <field name="res_model">receipt_printer.print.job</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
