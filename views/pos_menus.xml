<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Separate action for POS-context print jobs (pending filter by default) -->
    <record id="job_action_pos" model="ir.actions.act_window">
        <field name="name">Print Jobs</field>
        <field name="res_model">receipt_printer.print.job</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="job_view_search"/>
        <field name="context">{'search_default_filter_pending': 1}</field>
    </record>

    <!-- Backend menus under Point of Sale -->
    <menuitem id="menu_pos_printer"
              name="Printers"
              parent="point_of_sale.menu_point_root"
              action="printer_action"
              sequence="50"/>

    <menuitem id="menu_pos_print_jobs"
              name="Print Jobs"
              parent="point_of_sale.menu_point_root"
              action="job_action_pos"
              sequence="51"/>
</odoo>
