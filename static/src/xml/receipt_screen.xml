<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="receipt_printer.ReceiptScreenInherit" t-inherit="point_of_sale.ReceiptScreen" t-primary="1">
        <xpath expr="//div[hasclass('receipt-options')]" position="inside">
            <t t-if="hasThermalPrinter">
                <button class="button print btn btn-lg btn-success w-100 py-3"
                        t-on-click="() => sendToPrinter.call()">
                    <i t-attf-class="fa {{sendToPrinter.status === 'loading' ? 'fa-fw fa-spin fa-circle-o-notch' : 'fa-print'}} me-1" />
                    Send to Thermal Printer
                </button>
            </t>
        </xpath>
    </t>

</templates>
